<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:MyForce.Models"
        xmlns:viewModels="using:MyForce.ViewModels"
        x:Class="MyForce.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        mc:Ignorable="d"
        d:DesignWidth="1366"
        d:DesignHeight="768"
        MinWidth="1100"
        MinHeight="720"
        Width="1366"
        Height="768"
        Title="MyForce">
    <Window.Resources>
        <SolidColorBrush x:Key="ChassisBrush" Color="#050505" />
        <SolidColorBrush x:Key="FrameBrush" Color="#4D0F14" />
        <SolidColorBrush x:Key="FrameHighlightBrush" Color="#7C2027" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#5C5C5C" />
        <SolidColorBrush x:Key="PanelInnerBorderBrush" Color="#222222" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F4F6" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B4B7BC" />
        <SolidColorBrush x:Key="SignalTextBrush" Color="#A6DA5A" />
        <SolidColorBrush x:Key="AlertTextBrush" Color="#FF5F57" />
        <SolidColorBrush x:Key="ActiveBlueBrush" Color="#236CB8" />
        <SolidColorBrush x:Key="ActiveBlueBorderBrush" Color="#6CA7E8" />

        <LinearGradientBrush x:Key="PanelBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#242424" Offset="0" />
            <GradientStop Color="#141414" Offset="0.55" />
            <GradientStop Color="#090909" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#666666" Offset="0" />
            <GradientStop Color="#303030" Offset="0.28" />
            <GradientStop Color="#161616" Offset="0.7" />
            <GradientStop Color="#080808" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonHighlightBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#5E92D0" Offset="0" />
            <GradientStop Color="#2E6FB7" Offset="0.45" />
            <GradientStop Color="#174982" Offset="1" />
        </LinearGradientBrush>

        <DataTemplate x:Key="ComponentTemplate" x:DataType="models:SystemComponent">
            <Border Classes="framePanel"
                    Margin="0,0,0,12"
                    Padding="14">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Classes="primaryText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Text="{Binding Name}" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Classes="controlButton active"
                                Padding="14,10"
                                MinWidth="110">
                            <TextBlock Classes="primaryText"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Text="{Binding Status}" />
                        </Border>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,10,0,0"
                                   Classes="mutedText"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="COMPONENT ROLE" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,2,0,0"
                                   Classes="primaryText"
                                   TextWrapping="Wrap"
                                   Text="{Binding Role}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Classes="controlButton"
                                Padding="10,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="panelLabel"
                                           Text="PLANE" />
                                <TextBlock Classes="panelValue"
                                           FontSize="18"
                                           Text="{Binding Plane}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="controlButton"
                                Padding="10,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="panelLabel"
                                           Text="TRANSPORT" />
                                <TextBlock Classes="panelValue"
                                           FontSize="18"
                                           Text="{Binding Transport}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ConnectionTemplate" x:DataType="models:SystemConnection">
            <Border Classes="framePanel"
                    Margin="0,0,0,12"
                    Padding="12">
                <Grid ColumnDefinitions="1.7*,Auto,1.7*,1.4*,Auto">
                    <TextBlock Grid.Column="0"
                               Classes="primaryText"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Text="{Binding Source}" />
                    <Border Grid.Column="1"
                            Classes="controlButton active"
                            Margin="12,0"
                            Padding="12,8">
                        <TextBlock Classes="primaryText"
                                   FontWeight="Bold"
                                   Text="LINK" />
                    </Border>
                    <TextBlock Grid.Column="2"
                               Classes="primaryText"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Text="{Binding Target}" />
                    <Border Grid.Column="3"
                            Classes="controlButton"
                            Margin="16,0,0,0"
                            Padding="10,8">
                        <StackPanel Spacing="2">
                            <TextBlock Classes="panelLabel"
                                       Text="TRANSPORT" />
                            <TextBlock Classes="primaryText"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Text="{Binding Transport}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4"
                            Classes="controlButton active"
                            Margin="16,0,0,0"
                            Padding="12,8"
                            MinWidth="90">
                        <TextBlock Classes="primaryText"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Text="{Binding Plane}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TopicTemplate" x:DataType="models:MqttTopicGroup">
            <Border Classes="framePanel"
                    Margin="0,0,0,12"
                    Padding="14">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="2*,2.4*,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Classes="primaryText"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding Name}" />
                    <SelectableTextBlock Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="16,0,0,0"
                                         Foreground="{StaticResource SignalTextBrush}"
                                         FontWeight="Bold"
                                         Text="{Binding Topic}" />
                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Classes="controlButton"
                            Margin="16,0,0,0"
                            Padding="10,8">
                        <TextBlock Classes="primaryText"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Text="{Binding RetainLabel}" />
                    </Border>
                    <Border Grid.Row="0"
                            Grid.Column="3"
                            Classes="controlButton active"
                            Margin="8,0,0,0"
                            Padding="10,8">
                        <TextBlock Classes="primaryText"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Text="{Binding QosLabel}" />
                    </Border>
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="4"
                               Margin="0,10,0,0"
                               Classes="primaryText"
                               TextWrapping="Wrap"
                               Text="{Binding Purpose}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.titleText">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="30" />
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.panelLabel">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.panelValue">
            <Setter Property="Foreground" Value="{StaticResource SignalTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.primaryText">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style Selector="TextBlock.mutedText">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style Selector="Border.framePanel">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FrameBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BoxShadow" Value="0 0 0 1 #111111 inset" />
        </Style>

        <Style Selector="Border.controlButton">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BoxShadow" Value="0 1 0 0 #8A8A8A inset, 0 -1 0 0 #000000 inset" />
        </Style>

        <Style Selector="Border.controlButton.active">
            <Setter Property="Background" Value="{StaticResource ButtonHighlightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActiveBlueBorderBrush}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          Background="{StaticResource ChassisBrush}">
        <Border Padding="20,18,20,14"
                Background="{StaticResource ChassisBrush}"
                BorderBrush="{StaticResource FrameBrush}"
                BorderThickness="0,0,0,2">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="14">
                <WrapPanel HorizontalAlignment="Center"
                           ItemHeight="74"
                           ItemWidth="120"
                           Orientation="Horizontal">
                    <Border Classes="controlButton active" Margin="0,0,10,0" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="MODE" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="PATROL" />
                        </StackPanel>
                    </Border>
                    <Border Classes="controlButton" Margin="0,0,10,0" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="UNIT" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="L / S" />
                        </StackPanel>
                    </Border>
                    <Border Classes="controlButton" Margin="0,0,10,0" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="AUDIO" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="RADIO" />
                        </StackPanel>
                    </Border>
                    <Border Classes="controlButton" Margin="0,0,10,0" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="SENSOR" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="SCADA" />
                        </StackPanel>
                    </Border>
                    <Border Classes="controlButton" Margin="0,0,10,0" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="EXTERNAL" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="CAD" />
                        </StackPanel>
                    </Border>
                    <Border Classes="controlButton" Padding="14,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel" Text="EVENTS" />
                            <TextBlock Classes="primaryText" FontSize="18" FontWeight="Bold" Text="CAMERA" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="16">
                    <Border Grid.Column="0"
                            Classes="framePanel"
                            Padding="18,16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="titleText"
                                       Text="{Binding Title}" />
                            <TextBlock MaxWidth="760"
                                       Classes="primaryText"
                                       TextWrapping="Wrap"
                                       Text="{Binding Summary}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="controlButton"
                            Padding="18,14"
                            MinWidth="130">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel"
                                       Text="COMPONENTS" />
                            <TextBlock Classes="panelValue"
                                       Text="{Binding ComponentCount}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Classes="controlButton"
                            Padding="18,14"
                            MinWidth="130">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel"
                                       Text="CORE" />
                            <TextBlock Classes="panelValue"
                                       Text="{Binding CoreComponentCount}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Classes="controlButton active"
                            Padding="18,14"
                            MinWidth="130">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="panelLabel"
                                       Text="MQTT GROUPS" />
                            <TextBlock Classes="panelValue"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Text="{Binding TopicGroupCount}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="20"
                  ColumnDefinitions="1.2*,0.9*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="18"
                  RowSpacing="18">
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Classes="framePanel"
                        Padding="18">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="sectionTitle"
                                       Text="Application Components" />
                            <TextBlock Classes="mutedText"
                                       TextAlignment="Center"
                                       Text="Core and supporting modules defined by the current project framework." />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Components}"
                                      ItemTemplate="{StaticResource ComponentTemplate}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Classes="framePanel"
                        Padding="18">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="sectionTitle"
                                       Text="Connection Matrix" />
                            <TextBlock Classes="mutedText"
                                       TextAlignment="Center"
                                       Text="Representative transport links across the audio, control, and external planes." />
                        </StackPanel>

                        <Border Classes="controlButton"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="panelLabel"
                                           Text="Connections" />
                                <TextBlock Classes="panelValue"
                                           Text="{Binding ConnectionCount}" />
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Connections}"
                                      ItemTemplate="{StaticResource ConnectionTemplate}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Classes="framePanel"
                        Padding="18">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="sectionTitle"
                                       Text="MQTT Topic Taxonomy" />
                            <TextBlock Classes="mutedText"
                                       TextAlignment="Center"
                                       Text="The initial command, state, and configuration channels the UI will need to consume or publish." />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding TopicGroups}"
                                      ItemTemplate="{StaticResource TopicTemplate}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
